# ─────────────────────────────────────────────────────────────────────────────
# NorthStar Brand Copilot — single deployment config.
#
# 1. Copy this file to `config.env` (gitignored, never committed):
#       cp deployment/config.env.example deployment/config.env
# 2. Fill in the values below (produced during the setup/ phase).
# 3. Deploy:
#       bash deployment/deploy.sh
#       bash deployment/grant_resources.sh
#
# deploy.sh / grant_resources.sh source this file. The BUNDLE_VAR_* exports at
# the bottom feed the Databricks Asset Bundle variables (${var.*}) in
# agent_app/databricks.yml — you do NOT edit databricks.yml or app.yaml directly.
# ─────────────────────────────────────────────────────────────────────────────

# Databricks CLI profile (see `databricks auth profiles`)
export DATABRICKS_PROFILE="my-workspace"

# --- Resource IDs (created in the setup/ phase) ---
export CATALOG="my_catalog"                     # UC catalog holding the CPG tables + VS index
export SCHEMA="northstar_cpg"                    # schema within the catalog
export WAREHOUSE_ID="0123456789abcdef"           # SQL warehouse the agent uses for Genie/SQL
export GENIE_SPACE_ID="01f00000000000000000000000000000"   # Genie space id
export EXPERIMENT_ID="0000000000000000"          # MLflow experiment id
export LAKEBASE_INSTANCE_NAME="northstar-lakebase"

# --- Foundation Model endpoints (defaults are fine for most workspaces) ---
export MODEL_ENDPOINT="databricks-claude-sonnet-4-5"
export EMBEDDING_ENDPOINT="databricks-gte-large-en"

# ─── Bundle variable bindings — do not edit below this line ───────────────────
# Maps the values above onto the Asset Bundle variables in databricks.yml.
export BUNDLE_VAR_catalog="$CATALOG"
export BUNDLE_VAR_schema="$SCHEMA"
export BUNDLE_VAR_warehouse_id="$WAREHOUSE_ID"
export BUNDLE_VAR_genie_space_id="$GENIE_SPACE_ID"
export BUNDLE_VAR_experiment_id="$EXPERIMENT_ID"
export BUNDLE_VAR_lakebase_instance_name="$LAKEBASE_INSTANCE_NAME"
export BUNDLE_VAR_model_endpoint="$MODEL_ENDPOINT"
export BUNDLE_VAR_embedding_endpoint="$EMBEDDING_ENDPOINT"
